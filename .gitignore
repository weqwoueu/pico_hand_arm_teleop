*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
build/
dist/
.build/
*.whl
pip-wheel-metadata/

# ---- Virtual env / uv ----
.venv/
venv/
env/
.env
.env.*
!.env.example
.python-version.local
.uv-cache/

# ---- Test / coverage / cache ----
.pytest_cache/
